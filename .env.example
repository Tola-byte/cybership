# UPS OAuth credentials (required)
UPS_CLIENT_ID=ups_client_id
UPS_CLIENT_SECRET=ups_client_secret

# UPS account number used in rating payload (required)
UPS_SHIPPER_NUMBER=ups_shipper_number

# Environment switch
# true (or unset) = sandbox, false = production
UPS_USE_SANDBOX=true

# Optional overrides
# If set, overrides auth token endpoint completely.
UPS_OAUTH_TOKEN_URL=

# If set, adapter appends /shop or /rate automatically.
# Example base: https://wwwcie.ups.com/api/rating/v2409
UPS_RATING_BASE_URL=

# Optional transaction reference for UPS request tracing
UPS_CUSTOMER_CONTEXT=cybership-rate
